{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true,
    "rootDir": ".",
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "weave": ["./src/index.ts"],
      "weave/runtime": ["./src/runtime-entry.ts"],
      "weave/postgres": ["./src/postgres-entry.ts"],
      "weave/server": ["./src/server-entry.ts"],
      "weave/testing": ["./src/testing-entry.ts"],
      "weave/auth": ["./src/auth-entry.ts"],
      "weave/opencode": ["./src/opencode-entry.ts"]
    }
  },
  "include": ["src/**/*.ts"]
}
