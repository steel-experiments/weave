{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true,
    "rootDir": ".",
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "weave": ["./src/index.ts"],
      "weave/core": ["./src/core-entry.ts"],
      "weave/postgres": ["./src/postgres-entry.ts"]
    }
  },
  "include": ["src/**/*.ts"]
}
