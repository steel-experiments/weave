{
  "name": "weave",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./runtime": {
      "types": "./src/runtime-entry.ts",
      "import": "./src/runtime-entry.ts"
    },
    "./postgres": {
      "types": "./src/postgres-entry.ts",
      "import": "./src/postgres-entry.ts"
    },
    "./server": {
      "types": "./src/server-entry.ts",
      "import": "./src/server-entry.ts"
    },
    "./testing": {
      "types": "./src/testing-entry.ts",
      "import": "./src/testing-entry.ts"
    },
    "./auth": {
      "types": "./src/auth-entry.ts",
      "import": "./src/auth-entry.ts"
    }
  },
  "workspaces": [
    "examples/*"
  ],
  "scripts": {
    "db:migrate": "tsx src/scripts/migrate.ts",
    "poc": "tsx src/scripts/poc.ts",
    "system:poc": "tsx src/scripts/system-poc.ts",
    "auth:dry-run": "tsx src/scripts/auth-gateway-slice-51-dry-run.ts",
    "gates:list": "tsx src/scripts/development-operator.ts gates:list",
    "gates:show": "tsx src/scripts/development-operator.ts gates:show",
    "gates:approve": "tsx src/scripts/development-operator.ts gates:approve",
    "gates:reject": "tsx src/scripts/development-operator.ts gates:reject",
    "initiatives:list": "tsx src/scripts/development-operator.ts initiatives:list",
    "initiative:status": "tsx src/scripts/development-operator.ts initiative:status",
    "initiative:run": "tsx src/scripts/initiative-run.ts",
    "dashboard": "tsx src/scripts/dashboard.ts",
    "sre:demo": "tsx examples/sre-demo/src/index.ts",
    "assistant:demo": "tsx examples/simple-assistant/src/index.ts",
    "assistant:server": "tsx examples/simple-assistant/src/server.ts",
    "steel:demo": "tsx examples/steel-docs-sync/src/index.ts",
    "steel:webhook-demo": "tsx examples/steel-docs-sync/src/webhook-demo.ts",
    "otlp:smoke": "tsx src/scripts/otlp-smoke.ts",
    "server": "tsx src/scripts/server.ts",
    "daemon:runner": "tsx src/scripts/runner-daemon.ts",
    "daemon:tool": "tsx src/scripts/tool-daemon.ts",
    "typecheck": "tsc --noEmit && npm --workspace weave-sre-demo run typecheck && npm --workspace weave-steel-docs-sync run typecheck && npm --workspace weave-simple-assistant run typecheck && npm --workspace weave-prompt-workflow-review run typecheck",
    "test": "tsx src/tests/replay-authoring.test.ts && tsx src/tests/public-api-exports.test.ts && tsx src/tests/auth-gateway.test.ts && tsx src/tests/auth-audit.test.ts && tsx src/tests/auth-provider-adapter.test.ts && tsx src/tests/migration-compatibility.test.ts && tsx src/tests/development-orchestrator-contracts.test.ts && tsx src/tests/development-operator.test.ts && tsx src/tests/development-initiative-runner.test.ts && tsx src/tests/development-dashboard.test.ts && tsx src/tests/workspace-provider.test.ts && tsx src/tests/opencode-runner.test.ts && tsx src/tests/tool-worker-progress.test.ts && npm --workspace weave-prompt-workflow-review run test"
  },
  "dependencies": {
    "pg": "^8.16.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
