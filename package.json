{
  "name": "weave",
  "version": "0.0.0",
  "description": "Durable control plane for TypeScript agent systems.",
  "private": true,
  "license": "MIT",
  "author": "Steel",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/steel-experiments/weave.git"
  },
  "homepage": "https://github.com/steel-experiments/weave#readme",
  "bugs": {
    "url": "https://github.com/steel-experiments/weave/issues"
  },
  "type": "module",
  "keywords": [
    "agents",
    "durable-execution",
    "workflow",
    "event-sourcing",
    "typescript"
  ],
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core-entry.d.ts",
      "import": "./dist/core-entry.js"
    },
    "./postgres": {
      "types": "./dist/postgres-entry.d.ts",
      "import": "./dist/postgres-entry.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "tsx src/tests/public-api-exports.test.ts && tsx src/tests/migration-compatibility.test.ts && tsx src/tests/thread-service-reads.test.ts && tsx src/tests/inbox-routing-release.test.ts"
  },
  "dependencies": {
    "pg": "^8.16.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
