    "checkpoints:diff": "tsx src/scripts/development-operator.ts checkpoints:diff",
    "checkpoints:restore": "tsx src/scripts/development-operator.ts checkpoints:restore",
    "initiative:run": "tsx src/scripts/initiative-run.ts",
